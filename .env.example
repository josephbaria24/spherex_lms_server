# Server
NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spherex_lms

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
COOKIE_NAME=spherex_session
COOKIE_DOMAIN=
COOKIE_SECURE=false

# CORS / client
CLIENT_ORIGIN=http://localhost:3000

# Local file uploads (org logos, etc.)
UPLOADS_DIR=uploads

# Bunny.net (moved from lms-client)
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_PASSWORD=
BUNNY_STORAGE_REGION=sg
BUNNY_PULL_ZONE=
BUNNY_SECURITY_KEY=
